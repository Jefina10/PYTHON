# Write your MySQL query statement below
WITH ConsecutiveGroups AS (
    SELECT 
        *,
        id - ROW_NUMBER() OVER (ORDER BY id) AS id_diff
    FROM Stadium
    WHERE people >= 100
),
ValidGroups AS (
    SELECT 
        id_diff
    FROM ConsecutiveGroups
    GROUP BY id_diff
    HAVING COUNT(*) >= 3
)
SELECT 
    id, 
    visit_date, 
    people
FROM ConsecutiveGroups
WHERE id_diff IN (SELECT id_diff FROM ValidGroups)
ORDER BY visit_date;
