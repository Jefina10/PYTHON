class Solution:
    def findMedianSortedArrays(self, nums1: List[int], nums2: List[int]) -> float:
        # Ensure nums1 is the shorter array to optimize binary search
        if len(nums1) > len(nums2):
            nums1, nums2 = nums2, nums1
        
        m, n = len(nums1), len(nums2)
        low, high = 0, m
        half_len = (m + n + 1) // 2
        
        while low <= high:
            i = (low + high) // 2  # Partition index for nums1
            j = half_len - i       # Partition index for nums2
            
            # Boundary values for the four elements around the partition
            # Use +/- infinity for out-of-bounds cases
            max_left1 = nums1[i-1] if i > 0 else float('-inf')
            min_right1 = nums1[i] if i < m else float('inf')
            max_left2 = nums2[j-1] if j > 0 else float('-inf')
            min_right2 = nums2[j] if j < n else float('inf')
            
            # Check if partition is correct
            if max_left1 <= min_right2 and max_left2 <= min_right1:
                # Odd total length: median is the max of the left side
                if (m + n) % 2 == 1:
                    return float(max(max_left1, max_left2))
                # Even total length: average of the two middle elements
                return (max(max_left1, max_left2) + min(min_right1, min_right2)) / 2.0
            
            elif max_left1 > min_right2:
                # Move left in nums1
                high = i - 1
            else:
                # Move right in nums1
                low = i + 1
